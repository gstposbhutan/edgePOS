FROM alpine:latest
WORKDIR /app

# Copy the pre-downloaded PocketBase binary
COPY pb/pocketbase /app/pocketbase
RUN chmod +x /app/pocketbase

# Copy migrations
COPY pb/pb_migrations /app/pb_migrations

# Create data directory
RUN mkdir -p /app/pb_data

VOLUME /app/pb_data

EXPOSE 8090

CMD ["/app/pocketbase", "serve", "--http=0.0.0.0:8090", "--dir=/app/pb_data", "--migrationsDir=/app/pb_migrations"]
