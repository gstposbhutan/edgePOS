flowchart TD
    NOTE["Physical POS sale = customer present, pays immediately, invoice IS the receipt. Already built.\nThis flow covers online MARKETPLACE orders only — payment after delivery."]

    subgraph "Order Creation — 3 paths, identical order after creation"
        direction LR
        P1["Customer self-checkout\nPOST /api/shop/checkout\nvia /shop/checkout page"]
        P2["Vendor creates on behalf\nPOST /api/shop/orders\nneeds customer WhatsApp only"]
        P3["WhatsApp message\nGateway order-handler\n(F-WA-ORDER-001, already built)"]
    end

    P2 --> CREATE_MODAL["New Customer Order modal\ncomponents/pos/create-marketplace-order-modal\n- WhatsApp number (required)\n- Customer name (optional)\n- Delivery address (optional)\n- Product picker from vendor catalog"]
    CREATE_MODAL --> AUTO_CUST{Customer entity\nexists?}
    AUTO_CUST -->|No| AUTO_CREATE["Auto-create customer\nsame as OTP verify auto-signup\nentity role=CUSTOMER"]
    AUTO_CUST -->|Yes| ORDER_CREATED
    AUTO_CREATE --> ORDER_CREATED

    P1 & P3 --> ORDER_CREATED["MARKETPLACE order created\nstatus: CONFIRMED\nMKT-2026-XXXXX\npayment_method: CREDIT\nstock deducted via DB trigger"]

    ORDER_CREATED --> VENDOR_VIEW["/pos/orders — MARKETPLACE tab\nVendor sees the order"]
    VENDOR_VIEW --> INVOICE_BTN["Generate Invoice\nSame receipt format as POS sale\nPDF + WhatsApp send to customer"]
    INVOICE_BTN --> PATCH_PROC["PATCH status → PROCESSING\nVendor has confirmed + packed"]
    PATCH_PROC --> RIDER_ASSIGN["logistics-bridge:\nPOST /api/dispatch-delivery\nRider auto-assigned"]

    RIDER_ASSIGN --> PICKUP["Rider arrives at vendor\nPicks up package"]
    PICKUP --> WEBHOOK_PICK["Toofan/Rider webhook: PICKED_UP\nOrder → DISPATCHED\n(vendor does NOT set this)"]

    WEBHOOK_PICK --> DELIVERS["Rider delivers to customer"]
    DELIVERS --> WEBHOOK_DEL["Toofan/Rider webhook: DELIVERED\nOrder → DELIVERED\n(vendor does NOT set this)"]
    WEBHOOK_DEL --> PAY_LINK["AUTO: WhatsApp payment link\nsent to customer\n/pay/orderId?token=..."]

    PAY_LINK --> WAITING["Customer uploads payment screenshot\nOCR verifies amount"]
    WAITING --> COMPLETED["Order → COMPLETED\nInvoice locked"]

    COMPLETED --> INVOICE_VIEW["Invoice at /pos/order/[id]\nExisting receipt page\nPDF + WhatsApp"]

    ORDER_CREATED -->|CONFIRMED or PROCESSING| CANCEL["Cancel\nstock restored"]

    subgraph "Vendor fallback — Toofan not yet live"
        direction LR
        FB1["PATCH → DISPATCHED"] --> FB2["PATCH → DELIVERED"]
        FB2 --> FB3["Payment link auto-sent\nidentical result"]
    end
