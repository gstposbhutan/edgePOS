# Vendor Restock Flow (Retailer)

**Feature ID**: F-RESTOCK-001
**Last Updated**: 2026-04-26
**Actors**: Retailer Manager, Retailer Owner
**Access**: MANAGER and OWNER only (not CASHIER)

---

flowchart TD
    POS([POS Terminal /pos]) --> HEADER["POS Header"]
    HEADER --> ROLE_CHECK{sub_role?}
    ROLE_CHECK --> |CASHIER| HIDDEN["Restock button hidden"]
    ROLE_CHECK --> |MANAGER or OWNER| SHOW["ShoppingBag icon visible"]

    SHOW --> CLICK["Click Restock button"]
    CLICK --> OPEN_MODAL["Open RestockModal"]

    OPEN_MODAL --> FETCH_CONNS["fetchConnections hook"]
    FETCH_CONNS --> GET_RETAILER["Get retailer entity_id"]
    GET_RETAILER --> QUERY_RETAILER["SELECT FROM retailer_wholesalers"]
    QUERY_RETAILER --> JOIN_ENTITIES["JOIN entities for names"]
    JOIN_ENTITIES --> CONNECTIONS["Display connected wholesalers"]

    OPEN_MODAL --> STEP1{Step: Wholesalers}

    STEP1 --> LIST["WholesalerList component"]
    LIST --> SEARCH_WHOLE["Search by name"]
    LIST --> DISPLAY["Display: name, category, is_primary badge"]
    LIST --> CLICK_WHOLE["Click wholesaler card"]

    CLICK_WHOLE --> SET_SELECTED["Set selectedWholesaler"]
    SET_SELECTED --> STEP2["Step: Catalog"]

    STEP2 --> FETCH_CAT["fetchCatalog hook"]
    FETCH_CAT --> API_CAT["GET /api/wholesale/catalog?wholesaler_id"]
    API_CAT --> VERIFY_CONN{Verify connection?}
    VERIFY_CONN --> |No| ERROR_CONN["Error: Not connected"]
    VERIFY_CONN --> |Yes| GET_PRODUCTS["SELECT products WHERE created_by"]
    GET_PRODUCTS --> FILTER_VISIBLE["WHERE is_active=true AND wholesale_price>0"]
    FILTER_VISIBLE --> RETURN_PROD["Return products array"]

    STEP2 --> CATALOG["WholesalerCatalog component"]
    CATALOG --> SEARCH_PROD["Search products by name/SKU"]
    CATALOG --> GRID["Product grid"]
    GRID --> PRODUCT_CARD["Product card: name, price, unit, stock"]
    PRODUCT_CARD --> CLICK_PROD["Click to add"]

    CLICK_PROD --> ADD_CART["Add to cart array"]
    ADD_CART --> CHECK_EXISTS{In cart?}
    CHECK_EXISTS --> |Yes| INCR_QTY["Increment quantity"]
    CHECK_EXISTS --> |No| PUSH_NEW["Push new item"]

    STEP2 --> CART_PANEL["RestockCart component"]
    CART_PANEL --> CART_ITEMS["Cart items list"]
    CART_ITEMS --> ITEM["Item: name, unit_price, quantity"]
    ITEM --> QTY_CTRL["Quantity controls: -/+"]
    ITEM --> REMOVE["Remove button"]

    CART_PANEL --> TOTALS["Calculate totals"]
    TOTALS --> SUB["Subtotal = SUM unit_price * quantity"]
    TOTALS --> GST["GST = subtotal * 0.05"]
    TOTALS --> GRAND["Grand Total = subtotal + gst"]

    CART_PANEL --> PLACE_BTN["Place Purchase Order"]
    PLACE_BTN --> CHECK_ITEMS{Items > 0?}
    CHECK_ITEMS --> |No| DISABLED["Button disabled"]
    CHECK_ITEMS --> |Yes| ENABLED["Button enabled"]

    ENABLED --> CLICK_PLACE["Click Place Order"]
    CLICK_PLACE --> SUBMIT["placeOrder hook"]
    SUBMIT --> API_ORDER["POST /api/wholesale/orders"]
    API_ORDER --> GET_TOKEN["Get session access_token"]
    GET_TOKEN --> PAYLOAD["{ wholesaler_id, items }"]
    PAYLOAD --> POST_ORDERS["POST to API"]

    POST_ORDERS --> VALIDATE_BODY{Validate body}
    VALIDATE_BODY --> |Missing| ERROR_BODY["400: wholesaler_id and items required"]
    VALIDATE_BODY --> |Valid| AUTH_CHECK{"Bearer token"}

    AUTH_CHECK --> |Unauthorized| ERROR_AUTH["401: Unauthorized"]
    AUTH_CHECK --> |Authorized| ROLE_CHECK_API{Role check}
    ROLE_CHECK_API --> |Not RETAILER| ERROR_ROLE["403: Only retailers"]
    ROLE_CHECK_API --> |RETAILER| VERIFY_WHOLE{Verify connection}

    VERIFY_WHOLE --> |Not connected| ERROR_CONN_WHOLE["403: Not connected"]
    VERIFY_WHOLE --> |Connected| GET_PROD_DETAILS["Fetch product details"]

    GET_PROD_DETAILS --> CALC_TOTALS["Calculate order totals"]
    CALC_TOTALS --> CALC_GST["gst_total = subtotal * 0.05"]
    CALC_TOTALS --> CALC_GRAND["grand_total = subtotal + gst_total"]

    CALC_GRAND --> GEN_ORDER["Generate order_no"]
    GEN_ORDER --> YEAR["WHL-{year}-{serial}"]
    YEAR --> SERIAL["Increment serial"]

    SERIAL --> INSERT_ORD["INSERT orders"]
    INSERT_ORD --> SET_VALUES["order_type: WHOLESALE, status: CONFIRMED"]
    SET_VALUES --> SELLER_BUYER["seller_id: wholesaler, buyer_id: retailer"]
    SET_VALUES --> PAYMENT["payment_method: CREDIT"]

    PAYMENT --> INSERT_ITEMS["INSERT order_items"]
    INSERT_ITEMS --> TRIGGER_KHATA["Trigger: khata_debit_on_confirm"]

    TRIGGER_KHATA --> FIND_ACCOUNT["Find khata_account"]
    FIND_ACCOUNT --> CHECK_LIMIT{Check limit}
    CHECK_LIMIT --> |Exceeded| ERROR_LIMIT["RAISE: Credit limit exceeded"]
    CHECK_LIMIT --> |Within limit| DEBIT_BAL["outstanding_balance += grand_total"]

    DEBIT_BAL --> INSERT_DEBIT["INSERT DEBIT transaction"]
    INSERT_DEBIT --> CREATE_REPAY["INSERT khata_repayments"]
    CREATE_REPAY --> DUE_DATE["due_date = NOW + credit_term_days"]

    INSERT_ORD --> SUCCESS{Success?}
    SUCCESS --> |No| ERROR_INSERT["500: Failed to create order"]
    SUCCESS --> |Yes| CLEAR_CART["Clear cart array"]
    CLEAR_CART --> SHOW_SUCCESS["Show success message"]
    SHOW_SUCCESS --> CLOSE_MODAL["Close modal after 3s"]

