    class FETCH_CONNS,GET_RETAILER,QUERY_RETAILER,JOIN_ENTITIES,FETCH_CAT,GET_PRODUCTS,FILTER_VISIBLE,INSERT_ORD,INSERT_ITEMS,TRIGGER_KHATA,FIND_ACCOUNT,DEBIT_BAL,INSERT_DEBIT,CREATE_REPAY db
    class API_CAT,API_ORDER,POST_ORDERS api
