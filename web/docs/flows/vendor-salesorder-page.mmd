flowchart TD
    ORDERS["/pos/orders\nOrders list"] -->|"New Order button\n(MANAGER/OWNER/ADMIN only)"| SALESORDER["/salesorder\nSales Order page"]

    SALESORDER --> LAYOUT["Two-column keyboard layout\nLeft: customer details\nRight: order table"]

    LAYOUT --> CUSTOMER["Customer details\n- WhatsApp number (required)\n- Name (optional)\n- Delivery address (optional)\n- GPS button"]

    LAYOUT --> SEARCH_TRIGGER["Any keypress on order table\n→ Opens product search modal"]
    SEARCH_TRIGGER --> SEARCH_MODAL["Fullscreen product search\n(same as keyboard POS)\n1–9 shortcuts · ↑↓ navigate · Esc close\nBarcode scan: 8+ digits → direct add"]

    SEARCH_MODAL -->|"Product selected"| ORDER_TABLE["Order table\n# | Product | Qty | Unit | Total\nRow selection via ↑↓\nEnter = edit qty inline\nDel = remove row"]

    ORDER_TABLE --> TOTALS["Subtotal · GST 5% · Grand Total"]

    TOTALS -->|"F5 or Place Order button"| KHATA_CHECK{Khata account\nexists?}
    KHATA_CHECK -->|No| AUTO_CREATE["Auto-create CONSUMER\nkhata account\ncredit_limit: Nu. 1,000"]
    KHATA_CHECK -->|Yes| PLACE
    AUTO_CREATE --> PLACE

    PLACE["POST /api/shop/orders\n{ role: vendor, customer_whatsapp, items }"]
    PLACE --> DB["DB trigger: khata_debit_on_confirm\nDebits outstanding_balance\nLogs DEBIT transaction"]
    DB --> SUCCESS["Success screen\nOrder number shown\nNew Order / View Orders"]

    subgraph "Keyboard shortcuts"
        direction LR
        S1["Any key — Open search"]
        S2["↑↓ — Navigate rows"]
        S3["Enter — Edit qty"]
        S4["Del — Remove row"]
        S5["F5 — Place order"]
        S6["Esc — Go back"]
    end
