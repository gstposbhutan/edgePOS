# Wholesaler Signup Flow

**Feature ID**: F-WHOLESIGN-001
**Last Updated**: 2026-04-26
**Actors**: Distributor (creates), Wholesaler Owner (signs in)

---

flowchart TD
    START([Distributor Portal]) --> NAV[Navigate to Signup]
    NAV --> FORM["Wholesaler Signup Form"]

    FORM --> BIZ_DETAILS["Business Details"]
    BIZ_DETAILS --> NAME["Business Name"]
    BIZ_DETAILS --> WHATSAPP["WhatsApp Number E.164"]
    BIZ_DETAILS --> TPN["TPN / GSTIN"]

    FORM --> DIVIDER["─────"]

    FORM --> OWNER_DETAILS["Owner Account"]
    OWNER_DETAILS --> FULL_NAME["Full Name"]
    OWNER_DETAILS --> EMAIL["Email"]
    OWNER_DETAILS --> PASSWORD["Password min 6 chars"]

    FORM --> VALIDATE{Validate form}
    VALIDATE --> |Missing fields| ERROR["Show inline error"]
    VALIDATE --> |Valid| SUBMIT["POST /api/auth/signup/wholesaler"]

    SUBMIT --> API["Server: create wholesaler"]
    API --> CHECK_DB{Check TPN exists?}
    CHECK_DB --> |Yes| DUPE["Error: TPN already registered"]
    CHECK_DB --> |No| CREATE_ENTITY["INSERT entities"]
    CREATE_ENTITY --> SET_ROLE["role: WHOLESALER"]

    CREATE_ENTITY --> CREATE_USER["Supabase auth.createUser"]
    CREATE_USER --> APP_METADATA["app_metadata: entity_id, role, sub_role: OWNER"]

    CREATE_USER --> CREATE_PROFILE["INSERT user_profiles"]
    CREATE_PROFILE --> LINK["Link entity_id"]

    API --> SUCCESS{Success?}
    SUCCESS --> |No| SHOW_ERROR["Show error message"]
    SUCCESS --> |Yes| RETURN_TOKEN["Return access_token + refresh_token"]

    RETURN_TOKEN --> SET_SESSION["supabase.auth.setSession"]
    SET_SESSION --> REDIRECT["Redirect to /admin"]

    REDIRECT --> ADMIN_DASH([Admin Dashboard])

    classDef primary fill:#D4AF37,stroke:#D4AF37,color:#0F172A
