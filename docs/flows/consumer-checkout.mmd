flowchart TD
    C([Customer]) --> SHOP["/shop or /shop/store_[id]\nBrowse products"]

    SHOP --> AUTH_CHECK{Session active?}
    AUTH_CHECK -->|No| LOGIN["/login?redirect=/shop\nWhatsApp OTP required"]
    LOGIN -->|authenticated| SHOP
    AUTH_CHECK -->|Yes| CART["Add to Cart\none sub-cart per vendor"]

    CART --> DRAWER["Open CartDrawer\nItems grouped by store\nGST breakdown"]
    DRAWER --> CHECKOUT_BTN["Checkout button"]
    CHECKOUT_BTN --> CHECKOUT_PAGE["/shop/checkout\nOrder review"]

    CHECKOUT_PAGE --> SUMMARY["CheckoutSummary\nPer-vendor order sections\nGrand total with GST"]
    CHECKOUT_PAGE --> ADDRESS["Delivery address (required)\nGPS coordinates from browser"]
    ADDRESS --> PLACE["Place Order\nPOST /api/shop/checkout"]

    PLACE --> SPLIT["Per-vendor order split\none MARKETPLACE order per cart"]

    SPLIT --> ORDER_A["Vendor A\nstatus: CONFIRMED\nMKT-2026-XXXXX\npayment_method: CREDIT"]
    SPLIT --> ORDER_B["Vendor B\nstatus: CONFIRMED\nMKT-2026-XXXXX\npayment_method: CREDIT"]

    ORDER_A --> TRIGGER_A["DB trigger fires:\nstock deducted\ncart CONVERTED"]
    ORDER_B --> TRIGGER_B["DB trigger fires:\nstock deducted\ncart CONVERTED"]

    PLACE --> WA_CUST["WhatsApp to customer:\nOrders confirmed — pay after delivery"]
    PLACE --> WA_VEND_A["WhatsApp to Vendor A:\nNew marketplace order"]
    PLACE --> WA_VEND_B["WhatsApp to Vendor B:\nNew marketplace order"]

    PLACE --> ORDERS["/shop/orders\nCustomer order history"]
