sequenceDiagram
    participant C as Cashier
    participant POS as POS Page
    participant OTP as CustomerOtpModal
    participant GW as WhatsApp Gateway
    participant WA as WhatsApp
    participant DB as Supabase

    C->>POS: Select CREDIT payment method
    Note over POS: CREDIT button always enabled — no pre-identity needed

    C->>POS: Click Checkout
    POS->>OTP: Open CustomerOtpModal

    C->>OTP: Enter customer WhatsApp number
    OTP->>GW: POST /api/auth/whatsapp/send { phone }
    GW->>WA: OTP via WhatsApp (or mock: show in UI)
    WA-->>C: Customer shows OTP on their phone

    C->>OTP: Enter 6-digit OTP
    OTP->>DB: POST /api/auth/whatsapp/verify { phone, otp }
    DB-->>OTP: success

    OTP->>POS: onVerified(phone)
    POS->>DB: lookupAccount(phone) — khata_accounts WHERE debtor_phone = phone

    alt Khata account exists
        DB-->>POS: account { outstanding_balance, credit_limit }
        POS->>POS: Credit limit check
        alt Limit exceeded (non-owner)
            POS-->>C: Error: Credit limit exceeded
        else Limit OK or owner override
            POS->>POS: initiateCheckout()
        end
    else No account — auto-create
        POS->>DB: INSERT khata_accounts { creditor_entity_id, debtor_phone, credit_limit: 1000 }
        DB-->>POS: new account
        POS->>POS: initiateCheckout()
    end

    POS->>DB: INSERT orders { payment_method: CREDIT, status: CONFIRMED }
    DB->>DB: khata_debit_on_confirm trigger fires
    DB->>DB: UPDATE khata_accounts SET outstanding_balance += grand_total
    DB->>DB: INSERT khata_transactions (DEBIT)
    DB-->>POS: Order confirmed
