flowchart TD
    SIGNUP["/signup/retailer or /signup/wholesaler\nOwner creates account"] --> ENTITY["entities row created\nrole = RETAILER or WHOLESALER"]
    SIGNUP --> USER["auth user + user_profile\nsub_role = OWNER"]
    SIGNUP --> LINK["owner_stores row\nowner_id → entity_id\nis_primary = true"]

    USER -->|"Login → /pos"| POS_HEADER["POS Header\nStore name shown"]

    POS_HEADER -->|"Owner has 1 store"| SINGLE["Store name static — no dropdown"]
    POS_HEADER -->|"Owner has 2+ stores"| SELECTOR["Store selector dropdown\nShows all owned stores\nActive store highlighted"]

    SELECTOR -->|"Select different store"| SWITCH["POS context switches\nProducts · Cart · Orders · Khata\nall re-scope to new entity_id"]

    POS_HEADER -->|"Dashboard icon (OWNER only)"| ADMIN_STORES["/admin/stores\nStore management page"]

    ADMIN_STORES --> ADD_STORE["Add Store modal\nName (required) · TPN · WhatsApp"]
    ADD_STORE --> NEW_ENTITY["INSERT entities\nrole = RETAILER"]
    NEW_ENTITY --> NEW_LINK["INSERT owner_stores\nowner_id → new entity_id"]
    NEW_LINK --> SELECTOR

    ADMIN_STORES --> TEAM["/admin/team\nAdd MANAGER / CASHIER / STAFF\nto the currently active store"]
    TEAM --> TRANSFER["Transfer ownership\nSelect OWNER from role dropdown\nCurrent owner → MANAGER\nNew owner gets OWNER sub_role"]
