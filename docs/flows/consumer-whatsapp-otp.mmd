sequenceDiagram
    participant C as Consumer
    participant APP as Login Page
    participant API as Auth API
    participant GW as Gateway :3001
    participant META as Meta Cloud API
    participant WA as WhatsApp
    participant DB as Supabase

    C->>APP: Switch to WhatsApp tab
    C->>APP: Enter phone number
    APP->>API: POST /api/auth/whatsapp/send

    alt Mock mode (MOCK_WHATSAPP=true)
        API-->>APP: { mock: true, otp: "123456" }
        APP->>APP: Auto-fill OTP input and show "Demo OTP: 123456"
    else Production
        API->>DB: Store bcrypt(otp) in whatsapp_otps (5-min expiry)
        API->>GW: POST /api/send-otp
        GW->>META: Send template message
        META->>WA: Deliver OTP to consumer
        WA->>C: "Your code is XXXXXX. Valid for 5 minutes."
        API-->>APP: { success: true }
    end

    C->>APP: Enter 6-digit code
    APP->>API: POST /api/auth/whatsapp/verify { phone, otp }

    alt Mock mode — universal OTP 123456
        API->>API: Accept without DB check
    else Production
        API->>DB: Lookup unused non-expired OTP record
        API->>API: bcrypt.compare(otp, hash)
        alt Invalid OTP
            API-->>APP: 400 — Invalid OTP, N attempts remaining
        else Max attempts exceeded
            API->>DB: Mark OTP used
            API-->>APP: 400 — Too many attempts, request new OTP
        end
        API->>DB: Mark OTP used
    end

    API->>DB: SELECT entities WHERE whatsapp_no = phone

    alt New customer (no entity found)
        API->>DB: auth.admin.createUser (temp email + password)
        API->>DB: INSERT entities (role=CUSTOMER)
        API->>DB: INSERT user_profiles (role=CUSTOMER, sub_role=CUSTOMER)
        API->>DB: updateUserById — set user_metadata.phone + role
        API-->>APP: { needs_signin: true, email, temp_password }
        APP->>APP: signInWithPassword (2s delay for propagation)
        APP-->>C: Session established
    else Existing customer — orphaned entity (no user_profile)
        API->>DB: auth.admin.createUser
        API->>DB: INSERT user_profiles for existing entity
        API->>DB: updateUserById — set phone + role
        API-->>APP: { needs_signin: true, email, temp_password }
        APP->>APP: signInWithPassword
        APP-->>C: Session established
    else Existing customer — full account
        API->>DB: Sync role from user_profiles → user_metadata
        API->>DB: generateLink (magiclink) → access_token + refresh_token
        API-->>APP: { access_token, refresh_token }
        APP->>APP: supabase.auth.setSession(tokens)
        APP-->>C: Session established
    end

    APP->>APP: getRoleClaims(user)
    APP->>APP: redirect to ROLE_HOME[role]
    Note over APP: CUSTOMER → /shop
