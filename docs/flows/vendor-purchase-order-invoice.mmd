flowchart TD
    PURCHASES["/pos/purchases\nPurchases list page\nBreadcrumb: POS / Purchases\nTabs: Purchase Orders (PO) | Purchase Invoices (PI)"]

    PURCHASES -->|+ New PO button| NEW_PO["/pos/purchases/new\nNew Purchase Order\nBreadcrumb: POS / Purchases / New"]

    subgraph "Create Purchase Order"
        NEW_PO --> SUPPLIER["Supplier search\n(WHOLESALER entities)"]
        NEW_PO --> PO_SEARCH["Product search\nqueries product_batches with entity_id\nOnly products vendor has received before"]
        PO_SEARCH --> PO_ITEMS["Line items table\nQty + Unit Cost editable\nEnter=edit, Del=remove, ↑↓=navigate"]
        PO_ITEMS --> PO_META["Supplier ref, expected delivery\nPayment method (Online/Cash/Credit)"]
        PO_META -->|F5 Save PO| CREATE_PO["POST /api/purchases\norder_type = PURCHASE_ORDER\nstatus = DRAFT\nNo stock change"]
    end

    CREATE_PO --> PO_LIST["Purchase Orders list\nPO-YYYY-XXXXX\nDRAFT / SENT / PARTIALLY_RECEIVED / CONFIRMED"]

    PO_LIST -->|Click PO| PO_DETAIL["/pos/purchases/[id]\nBreadcrumb: POS / Purchases / PO-XXXX\nInfo: supplier, payment, expected delivery"]

    PO_DETAIL -->|F3 or 'Convert to Invoice' button| PI_OVERLAY["FULL-SCREEN CONVERT TO INVOICE OVERLAY\n\nLeft panel:\n- Payment Method (Online/Cash/Credit)\n- Supplier Invoice Ref\n- Line status summary\n- Keyboard shortcut guide\n\nRight panel:\n- One row per PO line item\n- Qty Received input\n- Unit Cost, MRP, Selling Price\n- Batch # (free text)\n- Expiry Date\n- + Batch button for split delivery\n- X to remove extra batch rows\n\nFooter: Total (ex-GST) · Create Purchase Invoice [F5]\nShortcutBar: ↑↓ Navigate · F5 Create · Esc Cancel"]

    PO_DETAIL -->|'Mark as Sent' button| SENT["PO → SENT\nSupplier notified"]
    PO_DETAIL -->|'Cancel PO' button| CANCELLED["PO → CANCELLED"]

    PI_OVERLAY --> PI_VALIDATE{"Sum of sub_batch qty\n= PO line qty\nfor all lines?"}
    PI_VALIDATE -->|Mismatch| PI_WARN["⚠ warning shown\nSubmit blocked"]
    PI_VALIDATE -->|Match| PI_SUBMIT["POST /api/purchases/[id]/convert\n\nServer validates qty per line"]

    PI_SUBMIT --> CREATE_PI["PURCHASE_INVOICE created at DRAFT\norder_items INSERT with batch details"]

    PI_SUBMIT --> PO_STATUS_UPDATE["PO status updated:\nPARTIALLY_RECEIVED if some lines remain\nCONFIRMED if all lines covered"]

    PO_LIST -->|Click PI| PI_DETAIL["/pos/purchases/[id]\nPurchase Invoice detail\nBreadcrumb: POS / Purchases / PI-XXXX"]

    PI_DETAIL -->|F4 or 'Confirm Receipt' button| CONFIRM_PI["POST /api/purchases/[id]/confirm\n\nPURCHASE_INVOICE → CONFIRMED\n→ restock_on_invoice_confirm trigger:\n  - product_batches INSERT (quantity=0)\n  - RESTOCK inventory_movements INSERT\n  - sync_batch_quantity increments batch.quantity\n  - order_items.batch_id back-filled\n  - products.wholesale_price updated\n  - orders.received_at = NOW()"]

    CONFIRM_PI --> SUCCESS_PI["✓ Goods Received & Stock Updated\nBatch(es) created\nPrint button available"]

    PI_DETAIL -->|Print button| PRINT_PI["PDF download\njsPDF + html2canvas\nPURCHASE INVOICE heading\nSupplier details\nLine items with batch numbers\nGST-compliant format"]
