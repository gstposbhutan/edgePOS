{
  "name": "pos-terminal",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "author": "NEXUS Bhutan <hello@nexus-bt.com>",
  "homepage": "https://nexus-bt.com",
  "description": "Offline-first GST POS Terminal for Bhutan — Next.js + PocketBase + Electron",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "pb:serve": "./pb/pocketbase serve --http=127.0.0.1:8090 --dir=./pb_data --migrationsDir=./pb/pb_migrations",
    "pb:setup": "node setup-pb.js",
    "test:e2e": "playwright test --project=pocketbase",
    "test:e2e:headed": "playwright test --project=pocketbase --headed",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder",
    "electron:pack": "next build && electron-builder --dir"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "escpos": "^3.0.0-alpha.6",
    "framer-motion": "^11.0.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "onnxruntime-web": "^1.18.0",
    "pocketbase": "^0.26.8",
    "pouchdb": "^8.0.1",
    "pouchdb-browser": "^8.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pouchdb": "^6.4.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^1.1.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "bt.nexus.pos-terminal",
    "productName": "NEXUS BHUTAN POS",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "pb/**/*",
      "pb_data/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Office",
      "icon": "public/favicon.ico"
    },
    "win": {
      "target": ["nsis"],
      "icon": "public/favicon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "public/favicon.ico",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
